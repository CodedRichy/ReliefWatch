# ReliefWatch Backend Configuration
# Copy this file to .env and fill in your values

# Application
DEBUG=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/reliefwatch

# Twitter/X API
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# News API
NEWSAPI_KEY=
